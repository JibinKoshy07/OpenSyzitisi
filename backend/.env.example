# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://mongo:27017/opensyzitisi

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=52428800

# Admin Account
ADMIN_EMAIL=admin@opensyzitisi.local
ADMIN_PASSWORD=admin123

# SMTP (Optional)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@opensyzitisi.local
